{
  "name": "kitchen-sink",
  "private": true,
  "scripts": {
    "docker:up": "docker compose --env-file .env.development.local up -d",
    "docker:down": "docker compose --env-file .env.development.local down",
    "build": "turbo run build",
    "clean": "turbo run clean",
    "dev": "turbo run dev",
    "format": "turbo run format",
    "lint": "turbo run lint",
    "test": "turbo run test",
    "check-types": "turbo run check-types",
    "check-unused": "turbo run check-unused",
    "check-spelling": "turbo run check-spelling",
    "check": "turbo run check"
  },
  "devDependencies": {
    "@cspell/dict-es-es": "^3.0.8",
    "@cspell/dict-pt-br": "^2.4.2",
    "turbo": "^2.8.16",
    "cspell": "^9.7.0"
  },
  "engines": {
    "node": ">=18"
  },
  "packageManager": "bun@1.3.1",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "cspell": {
    "import": [
      "@cspell/dict-pt-br/cspell-ext.json",
      "@cspell/dict-es-es/cspell-ext.json"
    ],
    "language": "en,es,pt,pt_BR",
    "ignorePaths": [
      "node_modules",
      "dist",
      ".vscode",
      "coverage"
    ],
    "words": [
      "claude",
      "healthcheck",
      "isready",
      "postgres",
      "postgresql",
      "rehydratable",
      "supabase",
      "turborepo"
    ]
  }
}
