{
  "name": "kitchen-sink",
  "private": true,
  "scripts": {
    "prepare": "husky",
    "docker:up": "docker compose --env-file .env.development.local up -d",
    "docker:down": "docker compose --env-file .env.development.local down",
    "build": "turbo run build",
    "clean": "turbo run clean",
    "dev": "turbo run dev",
    "format": "turbo run format",
    "lint": "turbo run lint",
    "test": "turbo run test",
    "check-types": "turbo run check-types",
    "check-unused": "turbo run check-unused",
    "check-spelling": "turbo run check-spelling",
    "check": "turbo run check"
  },
  "devDependencies": {
    "@commitlint/cli": "^20.4.2",
    "@commitlint/config-conventional": "^20.4.2",
    "@cspell/dict-es-es": "^3.0.8",
    "@cspell/dict-pt-br": "^2.4.2",
    "cspell": "^9.7.0",
    "husky": "^9.1.7",
    "rimraf": "6.0.1",
    "turbo": "^2.8.17",
    "validate-branch-name": "^1.3.2"
  },
  "engines": {
    "node": ">=18"
  },
  "packageManager": "bun@1.3.1",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "commitlint": {
    "extends": [
      "@commitlint/config-conventional"
    ],
    "rules": {
      "header-max-length": [
        2,
        "always",
        150
      ]
    }
  },
  "validate-branch-name": {
    "pattern": "^(main|dev){1}$|^(feat|fix|hotfix|chore|docs|refactor|ci|test|style)/.+$",
    "errorMsg": "Branch name invalid. Format: <type>/<description>. Example: feat/add-new-feature"
  },
  "cspell": {
    "import": [
      "@cspell/dict-pt-br/cspell-ext.json",
      "@cspell/dict-es-es/cspell-ext.json"
    ],
    "language": "en,es,pt,pt_BR",
    "ignorePaths": [
      "node_modules",
      "dist",
      ".vscode",
      "coverage"
    ],
    "words": [
      "claude",
      "healthcheck",
      "isready",
      "postgres",
      "postgresql",
      "rehydratable",
      "supabase",
      "turborepo"
    ]
  }
}
