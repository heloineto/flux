{
  "name": "flux-docs",
  "version": "0.0.0",
  "private": true,
  "scripts": {
    "build": "next build",
    "dev": "wait-on http-get://localhost:7100/openapi/json && next dev -p 7051",
    "start": "next start -p 7051",
    "lint": "eslint",
    "format": "prettier --write .",
    "check-types": "tsc --noEmit",
    "check-unused": "knip",
    "check-spelling": "cspell .",
    "check": "bun run check-types && bun run lint && bun run format && bun run check-unused && bun run check-spelling",
    "knip": "knip",
    "clean": "rimraf node_modules .next"
  },
  "dependencies": {
    "fumadocs-core": "16.6.17",
    "fumadocs-mdx": "14.2.10",
    "fumadocs-openapi": "10.3.18",
    "fumadocs-ui": "16.6.17",
    "next": "^16.1.6",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "shiki": "4.0.2",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@next/eslint-plugin-next": "^16.1.6",
    "@tailwindcss/postcss": "^4.2.1",
    "@types/bun": "^1.3.9",
    "@types/node": "^24.10.15",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "cspell": "^9.7.0",
    "eslint": "^9.39.3",
    "eslint-config-next": "^16.1.6",
    "eslint-plugin-zod": "^3.3.0",
    "knip": "^5.86.0",
    "postcss": "^8.5.6",
    "postcss-preset-mantine": "^1.18.0",
    "postcss-simple-vars": "^7.0.1",
    "prettier": "^3.8.1",
    "prettier-plugin-tailwindcss": "^0.7.2",
    "tailwindcss": "^4.2.1",
    "typescript": "^5.9.3",
    "wait-on": "^9.0.4"
  },
  "cspell": {
    "language": "en",
    "ignorePaths": [
      "node_modules",
      ".next",
      "*.tsbuildinfo",
      ".source"
    ],
    "words": [
      "frontmatter",
      "fumadoc",
      "fumadocs",
      "mdx",
      "nextjs",
      "orama",
      "rehydratable",
      "shiki",
      "supabase",
      "tailwindcss",
      "turborepo",
      "vercel",
      "waiton",
      "xstate"
    ]
  }
}
